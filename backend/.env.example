# AI API Keys Configuration Template
# Copy this file to .env and fill in your actual API keys

# 豆包 AI (Doubao) API Key - 用于食物识别和营养分析
DOUBAO_API_KEY=your_doubao_api_key_here

# 通义千问 (Qwen/Dashscope) API Key - 用于 AI 营养咨询
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# MySQL Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=health_assistant
DB_USERNAME=root
DB_PASSWORD=your_password_here

# JWT（生产环境务必使用长随机字符串）
JWT_SECRET=your_jwt_secret_at_least_32_chars_long
JWT_EXPIRATION_MS=86400000

# CORS 白名单（逗号分隔）
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 是否创建 testuser 测试账号（生产环境设为 false）
APP_SEED_TEST_USER=true
