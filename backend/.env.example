# AI API Keys Configuration Template
# Copy this file to .env and fill in your actual API keys

# DeepSeek — 平台默认：AI 对话 / 分析 / 食谱文案（试用不限次）
DEEPSEEK_API_KEY=your_deepseek_api_key_here
AI_DEEPSEEK_MODEL=deepseek-v4-flash

# 豆包 (火山方舟) — 平台默认：拍照识食 + AI 食谱配图（Seedream 生图）
DOUBAO_API_KEY=your_doubao_api_key_here
DOUBAO_API_KEY=your_doubao_api_key_here
# 火山方舟「推理接入点」ID（控制台复制 ep- 开头）
DOUBAO_VISION_MODEL=ep-xxxx-vision
# 火山方舟 Seedream 图片模型 ID（推荐 doubao-seedream-5-0-lite-260128）
# 若填 ep- 接入点，须为「图片生成」类模型；否则会回退到官方 Seedream ID
DOUBAO_IMAGE_MODEL=doubao-seedream-5-0-lite-260128
DOUBAO_IMAGE_SIZE=2K

# 通义（可选，用户自备）
DASHSCOPE_API_KEY=

# 平台试用配额（0 = 对话不限次）
AI_PLATFORM_TRIAL_ENABLED=true
AI_PLATFORM_TRIAL_TEXT_QUOTA=0
AI_PLATFORM_TRIAL_IMAGE_QUOTA=10
AI_PLATFORM_TRIAL_RECIPE_IMAGE_QUOTA=10
AI_IMAGE_RECOGNITION_ORDER=doubao,lmstudio,dashscope

# MySQL Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=health_assistant
DB_USERNAME=root
DB_PASSWORD=your_password_here

# JWT（生产环境务必使用长随机字符串）
JWT_SECRET=your_jwt_secret_at_least_32_chars_long
JWT_EXPIRATION_MS=86400000

# CORS 白名单（逗号分隔）
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

APP_SEED_TEST_USER=true
